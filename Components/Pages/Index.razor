@page "/"

<PageTitle>МузыкаМаркет — инструменты для вашего творчества</PageTitle>

<section class="hero-section">
    <div class="hero-bg-orb hero-orb-left"></div>
    <div class="hero-bg-orb hero-orb-right"></div>
    <div class="container position-relative text-center">
        <div class="hero-eyebrow">
            <i class="bi bi-stars"></i>
            Официальные дистрибьюторы Yamaha, Fender, Roland
        </div>
        <h1>Звучи профессионально.<br/><span class="hero-accent-line">Играй вдохновенно.</span></h1>
        <p class="hero-sub">Более 5 000 инструментов от ведущих мировых брендов.<br/>Доставка по всей России за 1 день.</p>
        <div class="hero-cta-row">
            <a class="hero-btn-primary" href="/catalog">
                <i class="bi bi-music-note-list"></i> Смотреть каталог
            </a>
            <a class="hero-btn-ghost" href="/purchases">
                <i class="bi bi-clock-history"></i> Мои заказы
            </a>
        </div>
        <div class="hero-notes-row" aria-hidden="true">
            <i class="bi bi-music-note-beamed"></i>
            <i class="bi bi-music-note"></i>
            <i class="bi bi-music-note-list"></i>
            <i class="bi bi-vinyl"></i>
            <i class="bi bi-music-note-beamed"></i>
        </div>
    </div>
</section>

<div class="stats-belt">
    <div class="container">
        <div class="stats-belt-grid">
            <div class="stats-item">
                <span class="stats-num">5 000+</span>
                <span class="stats-lbl">Инструментов</span>
            </div>
            <div class="stats-sep"></div>
            <div class="stats-item">
                <span class="stats-num">200+</span>
                <span class="stats-lbl">Мировых брендов</span>
            </div>
            <div class="stats-sep"></div>
            <div class="stats-item">
                <span class="stats-num">1 день</span>
                <span class="stats-lbl">Срок доставки</span>
            </div>
            <div class="stats-sep"></div>
            <div class="stats-item">
                <span class="stats-num">36 мес</span>
                <span class="stats-lbl">Гарантия</span>
            </div>
        </div>
    </div>
</div>

<section class="category-section">
    <div class="container">
        <div class="section-hdr">
            <h2 class="section-hdr-title">Выберите категорию</h2>
            <a href="/catalog" class="section-hdr-link">Весь каталог <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="category-grid">
            <a href="/catalog" class="cat-card cat-guitars">
                <i class="bi bi-music-note cat-icon"></i>
                <div class="cat-name">Гитары</div>
                <div class="cat-sub">Акустические, электро, бас</div>
            </a>
            <a href="/catalog" class="cat-card cat-keys">
                <i class="bi bi-keyboard cat-icon"></i>
                <div class="cat-name">Клавишные</div>
                <div class="cat-sub">Пианино, синтезаторы, MIDI</div>
            </a>
            <a href="/catalog" class="cat-card cat-drums">
                <i class="bi bi-circle-fill cat-icon"></i>
                <div class="cat-name">Ударные</div>
                <div class="cat-sub">Установки, перкуссия</div>
            </a>
            <a href="/catalog" class="cat-card cat-strings">
                <i class="bi bi-vinyl cat-icon"></i>
                <div class="cat-name">Струнные</div>
                <div class="cat-sub">Скрипки, виолончели</div>
            </a>
            <a href="/catalog" class="cat-card cat-winds">
                <i class="bi bi-broadcast cat-icon"></i>
                <div class="cat-name">Духовые</div>
                <div class="cat-sub">Саксофоны, трубы, флейты</div>
            </a>
        </div>
    </div>
</section>

<section class="promo-banner-section">
    <div class="container">
        <div class="promo-banner">
            <div class="promo-banner-left">
                <div class="promo-tag">Специальное предложение</div>
                <div class="promo-title">Настройка инструмента — в подарок</div>
                <div class="promo-desc">При любом заказе от 5 000 ₽ профессиональная настройка бесплатно</div>
                <a href="/catalog" class="promo-btn">Воспользоваться <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="promo-banner-right" aria-hidden="true">
                <i class="bi bi-music-note-beamed promo-deco-icon"></i>
            </div>
        </div>
    </div>
</section>

<section class="features-section">
    <div class="container">
        <h2 class="features-title text-center">Почему выбирают <span class="accent-text">МузыкаМаркет</span></h2>
        <div class="row g-4 mt-2">
            <div class="col-md-6">
                <div class="feat-row">
                    <div class="feat-icon"><i class="bi bi-patch-check-fill"></i></div>
                    <div>
                        <div class="feat-name">Оригинальные инструменты</div>
                        <div class="feat-desc">Прямые поставки от официальных дистрибьюторов Yamaha, Fender, Roland, Pearl</div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="feat-row">
                    <div class="feat-icon"><i class="bi bi-truck"></i></div>
                    <div>
                        <div class="feat-name">Быстрая доставка</div>
                        <div class="feat-desc">Отправка в день заказа. Бесплатная доставка при покупке от 8 000 ₽</div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="feat-row">
                    <div class="feat-icon"><i class="bi bi-shield-check"></i></div>
                    <div>
                        <div class="feat-name">Гарантия до 36 месяцев</div>
                        <div class="feat-desc">Официальная гарантия производителя на все инструменты из каталога</div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="feat-row">
                    <div class="feat-icon"><i class="bi bi-headset"></i></div>
                    <div>
                        <div class="feat-name">Консультация эксперта</div>
                        <div class="feat-desc">Музыканты-профессионалы помогут подобрать инструмент под ваш уровень и стиль</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
